# Database (PostgreSQL required)
DATABASE_URL="postgresql://postgres:password@localhost:5432/i9portal"

# Admin password is set in the browser on first visit to /admin.
# No env var needed — credentials are stored hashed in the database.

# PII Encryption — encrypts sensitive fields (SSN, address, DOB, etc.) at rest
# REQUIRED — generate with: openssl rand -hex 32
DATA_ENCRYPTION_KEY=""

# Email — Resend (preferred)
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# Email — SMTP fallback (used if RESEND_API_KEY is empty)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""

# File Storage
STORAGE_PROVIDER="local"    # local | s3

# S3 / Cloudflare R2
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Accounting Integrations ---
# Credentials are configured via the Admin > Integrations page.
# No env vars needed — client IDs/secrets are stored encrypted in the database.
# Token encryption keys are derived from DATA_ENCRYPTION_KEY automatically.
